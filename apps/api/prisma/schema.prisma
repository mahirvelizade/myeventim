generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  username    String?
  firstName   String
  lastName    String?
  language    String   @default("az")
  theme       String   @default("SYSTEM")
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invitations Invitation[]
  drafts      Draft[]
  favorites   FavoriteTemplate[]
  settings    UserSettings?
  analytics   AnalyticsEvent[]
  auditLogs   AuditLog[]
  files       GeneratedFile[]

  @@index([telegramId])
  @@index([language])
  @@index([createdAt])
}

model InvitationCategory {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  icon         String?
  thumbnailUrl String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  templates   InvitationTemplate[]
  invitations Invitation[]

  @@index([slug])
  @@index([isActive, order])
}

model InvitationTemplate {
  id           String   @id @default(cuid())
  categoryId   String
  name         String
  slug         String
  description  String?
  thumbnailUrl String?
  previewUrl   String?
  isPremium    Boolean  @default(false)
  isActive     Boolean  @default(true)
  metadata     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category    InvitationCategory @relation(fields: [categoryId], references: [id])
  favorites   FavoriteTemplate[]
  invitations Invitation[]

  @@index([categoryId])
  @@index([slug])
  @@index([isActive, categoryId])
  @@index([createdAt])
}

model Invitation {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String
  templateId  String
  title       String
  description String?
  data        Json
  status      String   @default("DRAFT")
  imageUrl    String?
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id])
  category InvitationCategory @relation(fields: [categoryId], references: [id])
  template InvitationTemplate @relation(fields: [templateId], references: [id])
  files    GeneratedFile[]

  @@index([userId])
  @@index([userId, status])
  @@index([categoryId])
  @@index([templateId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model GeneratedFile {
  id           String   @id @default(cuid())
  invitationId String
  userId       String
  format       String
  url          String
  size         Int
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())

  invitation Invitation @relation(fields: [invitationId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@index([invitationId])
  @@index([userId])
  @@index([invitationId, format])
}

model FavoriteTemplate {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  template InvitationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([userId])
  @@index([templateId])
}

model Draft {
  id         String   @id @default(cuid())
  userId     String
  categoryId String?
  templateId String?
  step       Int      @default(1)
  data       Json     @default("{}")
  status     String   @default("DRAFT")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([expiresAt])
  @@index([status, expiresAt])
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  language             String   @default("az")
  theme                String   @default("SYSTEM")
  notificationsEnabled Boolean  @default(true)
  autoSaveEnabled      Boolean  @default(true)
  highQualityExport    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AnalyticsEvent {
  id                 String   @id @default(cuid())
  userId             String?
  eventType          String
  categoryId         String?
  templateId         String?
  language           String?
  generationDuration Int?
  device             String?
  metadata           Json?
  timestamp          DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([eventType])
  @@index([eventType, timestamp])
  @@index([timestamp])
  @@index([userId, eventType])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([action, timestamp])
  @@index([entityType, entityId])
  @@index([timestamp])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(true)
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([key])
  @@index([enabled])
}

model BroadcastMessage {
  id          String   @id @default(cuid())
  text        String
  buttonText  String?
  buttonUrl   String?
  miniAppPath String?
  status      String   @default("PENDING")
  totalCount  Int      @default(0)
  sentCount   Int      @default(0)
  failedCount Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  @@index([status])
  @@index([createdAt])
}
