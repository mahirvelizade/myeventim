{
  "name": "invitely",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram Mini App for generating beautiful digital invitation cards",
  "license": "MIT",
  "author": "Mahir Vliyev",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @invitely/api db:generate",
    "db:push": "pnpm --filter @invitely/api db:push",
    "db:migrate": "pnpm --filter @invitely/api db:migrate",
    "db:seed": "pnpm --filter @invitely/api db:seed",
    "db:studio": "pnpm --filter @invitely/api db:studio",
    "prepare": "husky",
    "ci": "turbo run lint typecheck build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
