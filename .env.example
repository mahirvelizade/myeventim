# ─── Telegram ───────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username
ADMIN_ID=your_telegram_admin_id

# ─── Admin Panel ───────────────────────────────────────
# Password for admin panel login (alternative to Telegram ID)
# If not set, admin login will only work via Telegram ID
ADMIN_SECRET=change-this-to-a-secure-password

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://invitely:invitely@localhost:5432/invitely

# ─── Application ───────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development

# ─── Mini App ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BOT_USERNAME=your_bot_username

# ─── Storage ───────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# AWS S3 (for future use)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# Cloudflare R2 (for future use)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# Supabase Storage (for future use)
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_STORAGE_BUCKET=

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
